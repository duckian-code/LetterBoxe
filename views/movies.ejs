<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Movies — LetterBoxe</title>
    <link rel="stylesheet" href="/css/site.css" />
    <script defer src="/js/main.js"></script>
</head>
<body>

    <%- include('partials/header') %>

    <section class="movies-page" id="movies-page">
        <div class="movies-toolbar">
            <label for="movie-search" class="visually-hidden">Search movies</label>
            <input
                id="movie-search"
                class="movies-search"
                type="search"
                placeholder="Search movies..."
                autocomplete="off"
            />

            <label for="movie-category" class="visually-hidden">Browse by category</label>
            <select id="movie-category" class="movies-category" aria-label="Browse by category">
                <option value="all">Browse by category</option>
            </select>
        </div>

        <h1>All Movies</h1>

        <div class="movies-grid" id="movies-grid">
            <p class="empty-state">Loading movies...</p>
        </div>
    </section>

    <%- include('partials/footer') %>

</body>
</html>
