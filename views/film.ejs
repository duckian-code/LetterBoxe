<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Film — LetterBoxe</title>
  <link rel="stylesheet" href="/css/site.css" />
  <script defer src="/js/main.js"></script>
</head>
<body>

<main>
  <%- include('partials/header') %>
  <h1>Movies</h1>
</main>

  <div class="film-hero">
    <img src="<%= movie.poster %>" class="film-poster" alt="<%= movie.title %>" />
    <div class="film-details">
      <h1><%= movie.title %></h1>
      <p class="film-meta">
        <span><%= movie.year %></span>
        <% if (movie.director) { %><span><%= movie.director %></span><% } %>
        <% if (movie.runtime) { %><span><%= movie.runtime %> min</span><% } %>
      </p>
      <% if (movie.genres) { %>
        <div class="genre-tags">
          <% movie.genres.forEach(g => { %><span class="tag"><%= g %></span><% }) %>
        </div>
      <% } %>
      <p class="film-synopsis"><%= movie.synopsis %></p>
      <div class="film-actions">
        <div class="star-rating" data-movie-id="<%= movie._id %>">
          <% for (let i = 1; i <= 5; i++) { %>
            <span class="star <%= i <= (movie.rating || 0) ? 'active' : '' %>" data-val="<%= i %>">★</span>
          <% } %>
        </div>
        <button class="action-btn watchlist-btn">+ Watchlist</button>
        <button class="action-btn watched-btn">Watched</button>
      </div>
      <div class="film-stats">
        <div class="stat"><span class="stat-val"><%= movie.avgRating || '—' %></span><span class="stat-label">avg rating</span></div>
        <div class="stat"><span class="stat-val"><%= movie.watchCount || 0 %></span><span class="stat-label">watched</span></div>
        <div class="stat"><span class="stat-val"><%= movie.listCount || 0 %></span><span class="stat-label">lists</span></div>
      </div>
    </div>
  </div>

  <div class="film-body">

    <% if (movie.similar && movie.similar.length) { %>
      <div class="similar-section">
        <h2>More Like This</h2>
        <div class="film-row">
          <% movie.similar.forEach(m => { %>
            <div class="film-card">
              <img src="<%= m.poster %>" alt="<%= m.title %>">
              <p><%= m.title %></p>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

  </div>

  <%- include('partials/footer') %>

</body>
</html>
