<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Film — LetterBoxe</title>
  <link rel="stylesheet" href="/css/site.css" />
  <script defer src="/js/main.js"></script>
</head>
<body>

<main>
  <%- include('partials/header') %>
</main>
<!-- THE FOLLOWING SECTION IS A DEMO OF HOW TO USE THE DATA -->
<!-- Demo Object:
{
  "id": 1236153,
  "title": "Mercy",
  "poster": "https://image.tmdb.org/t/p/w500/pyok1kZJCfyuFapYXzHcy7BLlQa.jpg",
  "rating": 6.8,
  "releaseDate": "2026-01-20",
  "description": "In the near future, a detective stands on trial accused of murdering his wife. He has ninety minutes..."
}
-->
<!-- END OF DEMO -->

  <div class="film-hero">
    <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" class="film-poster" alt="<%= movie.title %> Poster" />
    <div class="film-details">
      <h1><%= movie.title %></h1>
      <p class="film-meta">
        <%= movie.overview %>>
      </p>
      <% if (movie.genres) { %>
        <div class="genre-tags">
          <% movie.genres.forEach(g => { %><span class="tag"><%= g %></span><% }) %>
        </div>
      <% } %>
      <p class="film-synopsis"><%= movie.synopsis %></p>
      <div class="film-actions">
        <div class="star-rating" data-movie-id="<%= movie._id %>">
          <% for (let i = 1; i <= 5; i++) { %>
            <span class="star <%= i <= (movie.rating || 0) ? 'active' : '' %>" data-val="<%= i %>">★</span>
          <% } %>
        </div>
      </div>
      <div class="watch-providers">
        <h2>Where to Watch</h2>
        <p class="watch-providers-list">Loading availability...</p>
      </div>
    </div>
  </div>

  <div class="film-body">

    <div class="similar-section">
      <h2>More Like This</h2>
      <div class="movies-toolbar" id="similar-filters">
        <label for="similar-genre-filter" class="visually-hidden">Filter similar movies by genre</label>
        <select id="similar-genre-filter" class="movies-category" aria-label="Filter similar movies by genre">
          <option value="shared">Shares a genre</option>
          <option value="all">All genres</option>
        </select>

        <label for="similar-min-rating" class="visually-hidden">Minimum rating</label>
        <input
          id="similar-min-rating"
          class="movies-search"
          type="number"
          min="0"
          max="10"
          step="0.1"
          placeholder="Min rating (0-10)"
        />

        <label for="similar-year-from" class="visually-hidden">Release year from</label>
        <input
          id="similar-year-from"
          class="movies-search"
          type="number"
          min="1900"
          max="2100"
          step="1"
          placeholder="Year from"
        />

        <label for="similar-year-to" class="visually-hidden">Release year to</label>
        <input
          id="similar-year-to"
          class="movies-search"
          type="number"
          min="1900"
          max="2100"
          step="1"
          placeholder="Year to"
        />

        <button id="similar-filters-reset" class="action-btn" type="button">Reset</button>
      </div>

      <div class="film-row" id="similar-movies-list">
        <p class="empty-state">Loading similar movies...</p>
      </div>
    </div>

  </div>

  <%- include('partials/footer') %>

</body>
</html>
